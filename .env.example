# TEDVHS Studio Configuration

# Application
DEBUG=False
APP_TITLE=TEDVHS Studio - Anime Clip Editor
WINDOW_WIDTH=1400
WINDOW_HEIGHT=900

# Paths
PROJECTS_DIR=./projects
CACHE_DIR=./cache
LOGS_DIR=./logs

# Database
DATABASE_URL=sqlite:///./data/tedvhs.db
DATABASE_ECHO=False

# Processing
MAX_WORKERS=4
TASK_TIMEOUT=3600

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

